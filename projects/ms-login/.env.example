# Domain (used by docker-compose.yml for nginx-proxy integration)
S_DOMAIN=ai.jingtao.fun

# Azure AD App Registration
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value

# OAuth redirect URI (must match Azure AD App Registration)
AZURE_REDIRECT_URI=https://ms-login.${S_DOMAIN}/auth/callback

# Session
SESSION_SECRET=generate-a-random-secret-here

# Shared secret for JWT signing (must match downstream services)
AUTH_SHARED_SECRET=generate-a-shared-secret-here

# Default callback URL for downstream service
NOTE_APP_CALLBACK_URL=https://note.${S_DOMAIN}/auth/callback

# Comma-separated whitelist of allowed callback URLs
ALLOWED_CALLBACKS=https://note.${S_DOMAIN}/auth/callback,https://auth-demo.${S_DOMAIN}/auth/callback
