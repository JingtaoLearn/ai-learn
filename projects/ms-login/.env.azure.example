# Azure AD App Registration
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# JWT shared secret (auto-generated if not set)
# AUTH_SHARED_SECRET=

# Default callback URL for downstream service
NOTE_APP_CALLBACK_URL=https://note.ai.jingtao.fun/auth/callback

# Comma-separated whitelist of allowed callback URLs
ALLOWED_CALLBACKS=https://note.ai.jingtao.fun/auth/callback,https://auth-demo.ai.jingtao.fun/auth/callback

# Azure deployment settings (optional)
# APP_NAME=ms-login-jingtao
# RESOURCE_GROUP=OpenClaw
# LOCATION=eastus
# SKU=B1
