# === Engine ===
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_HOOKS_TOKEN=
EXECUTOR_MODE=openclaw
API_AUTH_TOKEN=           # Bearer token for engine API (leave empty to disable auth)

# === EMS ===
EMS_EMBEDDING_API_KEY=
EMS_EMBEDDING_BASE_URL=https://litellm.us.jingtao.fun/v1
EMS_EMBEDDING_MODEL=text-embedding-3-large
EMS_LLM_API_KEY=          # Defaults to EMS_EMBEDDING_API_KEY if not set
EMS_LLM_BASE_URL=         # Defaults to EMS_EMBEDDING_BASE_URL if not set
EMS_LLM_MODEL=github-copilot/claude-sonnet-4.5
EMS_AUTH_TOKEN=           # Bearer token for EMS API (leave empty to disable auth)

# === Web (build-time Vite vars) ===
VITE_AZURE_CLIENT_ID=     # Azure AD app client ID (leave empty to disable MSAL auth)
VITE_AZURE_TENANT_ID=     # Azure AD tenant ID (leave empty to use 'common')
VITE_API_AUTH_TOKEN=      # Same as API_AUTH_TOKEN — baked into the web build

# === Deployment ===
S_DOMAIN=jingtao.fun
S_EMAIL=jingtao_buaa@icloud.com
