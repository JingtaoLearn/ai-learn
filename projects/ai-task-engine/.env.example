# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here
DISCORD_ENABLED=true

# EMS Integration
EMS_BASE_URL=http://127.0.0.1:8100

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_HOOKS_TOKEN=your_openclaw_hooks_token_here

# Database
DB_PATH=./data/task-engine.db

# API Server
API_PORT=3200

# Executor Mode: mock | openclaw
EXECUTOR_MODE=mock

# Logging
LOG_LEVEL=info
