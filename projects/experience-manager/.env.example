# Required: API key for the LiteLLM embedding proxy
EMS_EMBEDDING_API_KEY=your-api-key-here

# Optional: Embedding service overrides
EMS_EMBEDDING_BASE_URL=https://litellm.us.jingtao.fun/v1
EMS_EMBEDDING_MODEL=text-embedding-3-large

# Optional: LLM service for check/learn AI judgment (defaults to embedding key/url)
EMS_LLM_API_KEY=
EMS_LLM_BASE_URL=
EMS_LLM_MODEL=github-copilot/claude-sonnet-4.5
