# Required: API key for the LiteLLM embedding proxy
EMS_EMBEDDING_API_KEY=your-api-key-here

# Optional overrides
EMS_EMBEDDING_BASE_URL=https://litellm.us.jingtao.fun/v1
EMS_EMBEDDING_MODEL=text-embedding-3-large

# Domain for HTTPS (used by nginx-proxy)
EMS_VIRTUAL_HOST=ems.ai.jingtao.fun

# Admin email for Let's Encrypt SSL certificates
S_EMAIL=admin@example.com
